# Autopulse — environment variables
# Copy this file to .env and fill in your values. NEVER commit .env

# Future backend API endpoint (not used in current frontend-only build)
PUBLIC_API_URL=http://localhost:3000

# Optional: enable analytics in production
# PUBLIC_ANALYTICS_ID=

# Server-side secrets (not exposed to client). Used when backend is added.
# DATABASE_URL=
# JWT_SECRET=
# STRIPE_SECRET_KEY=
